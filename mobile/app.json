{
  "expo": {
    "name": "wroom",
    "slug": "wroom",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/wroom-icon-cream.png",
    "scheme": "wroom",
    "userInterfaceStyle": "automatic",
    "extra": {
      "apiBaseUrl": "https://wroom-api.joseppy-workers.workers.dev",
      "router": {},
      "eas": {
        "projectId": "82e44798-a33d-4d3f-9cac-bb5023959994"
      }
    },
    "ios": {
      "bundleIdentifier": "io.wroom.app",
      "supportsTablet": false,
      "icon": "./assets/images/wroom-icon-ios.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "wroom uses your photo library so you can set avatars and banners for your characters.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "io.wroom.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf8f5",
          "image": "./assets/images/wroom-wordmark-black-dot-transparent.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0c0a09",
            "image": "./assets/images/wroom-wordmark-white-transparent.png"
          }
        }
      ],
      "expo-sharing",

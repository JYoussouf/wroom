{
  "name": "wroom",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Writer's Room — a fiction studio disguised as a social network. One author, many identities.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "ios": "npm run build && cap sync ios && cap open ios",
    "sync": "npm run build && cap sync ios",
    "server:dev": "npm --prefix server run dev",
    "server:deploy": "npm --prefix server run deploy",
    "server:migrate:local": "npm --prefix server run migrate:local",
    "server:migrate:remote": "npm --prefix server run migrate:remote"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^4.100.0"
  }
}
